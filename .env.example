# このファイルは見本です。値を埋めて `.env` にコピーして使ってください。
#   cp .env.example .env
# `.env` は .gitignore 済みなのでコミットされません。

# サーバーの待受ポート。
# 本番はデプロイ先プラットフォームが PORT を注入するため、通常は設定不要。
# 未設定の場合はアプリ側デフォルト(8080)で起動します。
PORT=8080

# CORS で許可するオリジン。カンマ区切りで複数指定できます。
# 例: CORS_ALLOW_ORIGINS=http://localhost:3000,https://app.example.com
# 未設定の場合は「何も許可しない」(空)で起動します。
CORS_ALLOW_ORIGINS=http://localhost:3000
